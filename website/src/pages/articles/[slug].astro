---
import ArticleNavigation from '@components/ArticleNavigation.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import Sidebar from '@components/Sidebar.astro';
import TagList from '@components/TagList.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { render } from 'astro:content';
import { getPublishedArticles, type ArticleEntry } from '@utils/articles';
import { getCategoryTree, type CategoryTree } from '@utils/categories';
import { findArticleNavigation } from '@utils/navigation';

export async function getStaticPaths() {
  const articles = await getPublishedArticles();

  return articles.map((article) => ({
    params: {
      slug: article.data.slug,
    },
    props: {
      article,
      navigation: findArticleNavigation(articles, article.data.slug),
    },
  }));
}

interface Props {
  article: ArticleEntry;
  navigation: ReturnType<typeof findArticleNavigation>;
}

const { article, navigation } = Astro.props;
const categoryTree: CategoryTree = await getCategoryTree();
const { Content } = await render(article);
---

<BaseLayout
  title={`${article.data.title} / Запретные знания`}
  description={article.data.description}
>
  <main class="mx-auto grid max-w-7xl gap-8 px-6 py-12 lg:grid-cols-[320px_1fr]">
    <Sidebar categoryTree={categoryTree} currentSlug={article.data.slug} />

    <div>
      <Breadcrumbs
        items={[
          { label: 'Главная', href: '/' },
          { label: 'Статьи', href: '/articles' },
          { label: article.data.title },
        ]}
      />

      <article class="mt-8">
        <header>
          <p class="text-sm text-[var(--color-muted)]">
            {article.data.date} /{' '}
            <a href={`/categories/${encodeURIComponent(article.data.category)}`}>
              {article.data.category}
            </a>{' '}
            /{' '}
            <a
              href={`/subcategories/${encodeURIComponent(article.data.subcategory)}`}
            >
              {article.data.subcategory}
            </a>
          </p>
          <h1 class="mt-3 text-4xl font-semibold leading-tight">
            {article.data.title}
          </h1>
          <p class="mt-4 text-lg leading-8 text-[var(--color-muted)]">
            {article.data.description}
          </p>
          <div class="mt-5">
            <TagList tags={article.data.tags} />
          </div>
          <img
            src={article.data.cover}
            alt=""
            class="mt-8 aspect-video w-full rounded-md border border-[var(--color-border)] object-cover"
          />
        </header>

        <div class="article-content mt-10">
          <Content />
        </div>
      </article>

      <ArticleNavigation navigation={navigation} />
    </div>
  </main>
</BaseLayout>
