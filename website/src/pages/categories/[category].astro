---
import BaseLayout from '@layouts/BaseLayout.astro';
import type { ArticleEntry } from '@utils/articles';
import { getCategoryTree } from '@utils/categories';

export async function getStaticPaths() {
  const categoryTree = await getCategoryTree();

  return categoryTree.map((category) => ({
    params: {
      category: category.category,
    },
    props: {
      category: category.category,
      subcategories: category.subcategories,
    },
  }));
}

interface Props {
  category: string;
  subcategories: {
    subcategory: string;
    articles: ArticleEntry[];
  }[];
}

const { category, subcategories } = Astro.props;
const articles = subcategories.flatMap((subcategory) => subcategory.articles);
const tags = [...new Set(articles.flatMap((article) => article.data.tags))].sort(
  (firstTag, secondTag) => firstTag.localeCompare(secondTag, 'ru'),
);
---

<BaseLayout
  title={`${category} / Запретные знания`}
  description={`Статьи категории ${category}.`}
>
  <main class="mx-auto max-w-6xl px-6 py-12">
    <nav class="text-sm text-[var(--color-muted)]">
      <a href="/">Главная</a>
      <span class="mx-2">/</span>
      <span>{category}</span>
    </nav>

    <header class="mt-8">
      <h1 class="text-4xl font-semibold">{category}</h1>
      <p class="mt-4 text-[var(--color-muted)]">
        {articles.length} опубликованные статьи
      </p>
    </header>

    <section class="mt-8">
      <h2 class="text-2xl font-semibold">Подкатегории</h2>
      <div class="mt-5 grid gap-5">
        {
          subcategories.map((subcategory) => (
            <article class="rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] p-5">
              <h3 class="text-xl font-semibold">
                <a
                  href={`/subcategories/${encodeURIComponent(subcategory.subcategory)}`}
                >
                  {subcategory.subcategory}
                </a>
              </h3>
              <ul class="mt-4 space-y-3">
                {subcategory.articles.map((article) => (
                  <li>
                    <a
                      class="font-medium text-[var(--color-accent)]"
                      href={`/articles/${article.data.slug}`}
                    >
                      {article.data.title}
                    </a>
                    <p class="mt-1 text-sm text-[var(--color-muted)]">
                      {article.data.description}
                    </p>
                  </li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </section>

    <section class="mt-10 border-t border-[var(--color-border)] pt-8">
      <h2 class="text-2xl font-semibold">Теги категории</h2>
      <div class="mt-5 flex flex-wrap gap-2">
        {
          tags.map((tag) => (
            <a
              class="rounded-md border border-[var(--color-border)] px-3 py-2 text-sm"
              href={`/tags/${encodeURIComponent(tag)}`}
            >
              {tag}
            </a>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
