---
import ArticleCard from '@components/ArticleCard.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import Sidebar from '@components/Sidebar.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import type { ArticleEntry } from '@utils/articles';
import { getCategoryTree } from '@utils/categories';
import { getTagIndex } from '@utils/tags';

export async function getStaticPaths() {
  const tagIndex = await getTagIndex();

  return tagIndex.map((tag) => ({
    params: {
      tag: tag.tag,
    },
    props: {
      tag: tag.tag,
      count: tag.count,
      articles: tag.articles,
    },
  }));
}

interface Props {
  tag: string;
  count: number;
  articles: ArticleEntry[];
}

const { tag, count, articles } = Astro.props;
const categoryTree = await getCategoryTree();
---

<BaseLayout
  title={`Тег ${tag} / Запретные знания`}
  description={`Статьи с тегом ${tag}.`}
>
  <main class="mx-auto grid max-w-7xl gap-8 px-6 py-12 lg:grid-cols-[320px_1fr]">
    <Sidebar categoryTree={categoryTree} />

    <div>
      <Breadcrumbs items={[{ label: 'Главная', href: '/' }, { label: `#${tag}` }]} />

      <header class="mt-8">
        <h1 class="text-4xl font-semibold">#{tag}</h1>
        <p class="mt-4 text-[var(--color-muted)]">
          {count} опубликованные статьи
        </p>
      </header>

      <section class="mt-10 grid gap-5">
        {
          articles.map((article) => (
            <ArticleCard article={article} showCover={false} showTags={false} />
          ))
        }
      </section>
    </div>
  </main>
</BaseLayout>
