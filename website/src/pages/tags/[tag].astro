---
import ArticleCard from '@components/ArticleCard.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import type { ArticleEntry } from '@utils/articles';
import { getTagIndex } from '@utils/tags';

export async function getStaticPaths() {
  const tagIndex = await getTagIndex();

  return tagIndex.map((tag) => ({
    params: {
      tag: tag.tag,
    },
    props: {
      tag: tag.tag,
      count: tag.count,
      articles: tag.articles,
    },
  }));
}

interface Props {
  tag: string;
  count: number;
  articles: ArticleEntry[];
}

const { tag, count, articles } = Astro.props;
---

<BaseLayout
  title={`Тег ${tag} / Запретные знания`}
  description={`Статьи с тегом ${tag}.`}
>
  <main class="mx-auto max-w-5xl px-6 py-12">
    <Breadcrumbs items={[{ label: 'Главная', href: '/' }, { label: `#${tag}` }]} />

    <header class="mt-8">
      <h1 class="text-4xl font-semibold">#{tag}</h1>
      <p class="mt-4 text-[var(--color-muted)]">
        {count} опубликованные статьи
      </p>
    </header>

    <section class="mt-10 grid gap-5">
      {
        articles.map((article) => (
          <ArticleCard article={article} showCover={false} showTags={false} />
        ))
      }
    </section>
  </main>
</BaseLayout>
