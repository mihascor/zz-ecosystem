---
import BaseLayout from '@layouts/BaseLayout.astro';
import type { ArticleEntry } from '@utils/articles';
import { getTagIndex } from '@utils/tags';

export async function getStaticPaths() {
  const tagIndex = await getTagIndex();

  return tagIndex.map((tag) => ({
    params: {
      tag: tag.tag,
    },
    props: {
      tag: tag.tag,
      count: tag.count,
      articles: tag.articles,
    },
  }));
}

interface Props {
  tag: string;
  count: number;
  articles: ArticleEntry[];
}

const { tag, count, articles } = Astro.props;
---

<BaseLayout
  title={`Тег ${tag} / Запретные знания`}
  description={`Статьи с тегом ${tag}.`}
>
  <main class="mx-auto max-w-5xl px-6 py-12">
    <nav class="text-sm text-[var(--color-muted)]">
      <a href="/">Главная</a>
      <span class="mx-2">/</span>
      <span>{tag}</span>
    </nav>

    <header class="mt-8">
      <h1 class="text-4xl font-semibold">#{tag}</h1>
      <p class="mt-4 text-[var(--color-muted)]">
        {count} опубликованные статьи
      </p>
    </header>

    <section class="mt-10 grid gap-5">
      {
        articles.map((article) => (
          <article class="rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] p-5">
            <p class="text-sm text-[var(--color-muted)]">
              <a href={`/categories/${encodeURIComponent(article.data.category)}`}>
                {article.data.category}
              </a>{' '}
              /{' '}
              <a
                href={`/subcategories/${encodeURIComponent(article.data.subcategory)}`}
              >
                {article.data.subcategory}
              </a>
            </p>
            <h2 class="mt-2 text-2xl font-semibold">
              <a href={`/articles/${article.data.slug}`}>
                {article.data.title}
              </a>
            </h2>
            <p class="mt-3 leading-7 text-[var(--color-muted)]">
              {article.data.description}
            </p>
          </article>
        ))
      }
    </section>
  </main>
</BaseLayout>
