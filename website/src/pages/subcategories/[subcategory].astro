---
import ArticleCard from '@components/ArticleCard.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import type { ArticleEntry } from '@utils/articles';
import { getCategoryTree } from '@utils/categories';

export async function getStaticPaths() {
  const categoryTree = await getCategoryTree();

  return categoryTree.flatMap((category) =>
    category.subcategories.map((subcategory) => ({
      params: {
        subcategory: subcategory.subcategory,
      },
      props: {
        category: category.category,
        subcategory: subcategory.subcategory,
        articles: subcategory.articles,
      },
    })),
  );
}

interface Props {
  category: string;
  subcategory: string;
  articles: ArticleEntry[];
}

const { category, subcategory, articles } = Astro.props;
---

<BaseLayout
  title={`${subcategory} / Запретные знания`}
  description={`Статьи подкатегории ${subcategory}.`}
>
  <main class="mx-auto max-w-5xl px-6 py-12">
    <Breadcrumbs
      items={[
        { label: 'Главная', href: '/' },
        { label: category, href: `/categories/${encodeURIComponent(category)}` },
        { label: subcategory },
      ]}
    />

    <header class="mt-8">
      <h1 class="text-4xl font-semibold">{subcategory}</h1>
      <p class="mt-4 text-[var(--color-muted)]">
        Статьи отсортированы по порядку чтения.
      </p>
    </header>

    <section class="mt-10 grid gap-5">
      {
        articles.map((article) => (
          <ArticleCard article={article} showCover={false} showTags={false} />
        ))
      }
    </section>
  </main>
</BaseLayout>
