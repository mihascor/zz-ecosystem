---
import BaseLayout from '@layouts/BaseLayout.astro';
import type { ArticleEntry } from '@utils/articles';
import { getCategoryTree } from '@utils/categories';

export async function getStaticPaths() {
  const categoryTree = await getCategoryTree();

  return categoryTree.flatMap((category) =>
    category.subcategories.map((subcategory) => ({
      params: {
        subcategory: subcategory.subcategory,
      },
      props: {
        category: category.category,
        subcategory: subcategory.subcategory,
        articles: subcategory.articles,
      },
    })),
  );
}

interface Props {
  category: string;
  subcategory: string;
  articles: ArticleEntry[];
}

const { category, subcategory, articles } = Astro.props;
---

<BaseLayout
  title={`${subcategory} / Запретные знания`}
  description={`Статьи подкатегории ${subcategory}.`}
>
  <main class="mx-auto max-w-5xl px-6 py-12">
    <nav class="text-sm text-[var(--color-muted)]">
      <a href="/">Главная</a>
      <span class="mx-2">/</span>
      <a href={`/categories/${encodeURIComponent(category)}`}>{category}</a>
      <span class="mx-2">/</span>
      <span>{subcategory}</span>
    </nav>

    <header class="mt-8">
      <h1 class="text-4xl font-semibold">{subcategory}</h1>
      <p class="mt-4 text-[var(--color-muted)]">
        Статьи отсортированы по порядку чтения.
      </p>
    </header>

    <section class="mt-10 grid gap-5">
      {
        articles.map((article) => (
          <article class="rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] p-5">
            <p class="text-sm text-[var(--color-muted)]">
              Порядок: {article.data.order} / {article.data.date}
            </p>
            <h2 class="mt-2 text-2xl font-semibold">
              <a href={`/articles/${article.data.slug}`}>
                {article.data.title}
              </a>
            </h2>
            <p class="mt-3 leading-7 text-[var(--color-muted)]">
              {article.data.description}
            </p>
          </article>
        ))
      }
    </section>
  </main>
</BaseLayout>
