---
import ArticleCard from '@components/ArticleCard.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { getPublishedArticles } from '@utils/articles';
import { getCategoryTree } from '@utils/categories';
import { getTagIndex } from '@utils/tags';

const latestArticles = (await getPublishedArticles('date')).slice(0, 3);
const categoryTree = await getCategoryTree();
const tags = await getTagIndex();
---

<BaseLayout
  title="Запретные знания"
  description="Локальный сайт-блог для последовательного чтения статей проекта «Запретные знания»."
>
  <main class="mx-auto max-w-6xl px-6 py-12">
    <section class="py-12">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-[var(--color-accent)]">
        Локальный сайт-блог
      </p>
      <h1 class="max-w-3xl text-4xl font-semibold leading-tight sm:text-5xl">
        Запретные знания
      </h1>
      <p class="mt-5 max-w-2xl text-lg leading-8 text-[var(--color-muted)]">
        Контентный сайт для последовательного и выборочного чтения материалов
        по категориям, подкатегориям и тегам.
      </p>
      <a
        href="/articles"
        class="mt-8 inline-flex rounded-md bg-[var(--color-text)] px-5 py-3 text-sm font-semibold text-[var(--color-surface)]"
      >
        Все статьи
      </a>
    </section>

    <section class="border-t border-[var(--color-border)] py-10">
      <h2 class="text-2xl font-semibold">Последние статьи</h2>
      <div class="mt-6 grid gap-5 md:grid-cols-3">
        {
          latestArticles.map((article) => (
            <ArticleCard article={article} showCover={false} showTags={false} compact />
          ))
        }
      </div>
    </section>

    <section class="grid gap-10 border-t border-[var(--color-border)] py-10 md:grid-cols-2">
      <div>
        <h2 class="text-2xl font-semibold">Категории</h2>
        <ul class="mt-5 space-y-3">
          {
            categoryTree.map((category) => (
              <li>
                <a
                  class="font-medium text-[var(--color-accent)]"
                  href={`/categories/${encodeURIComponent(category.category)}`}
                >
                  {category.category}
                </a>
                <span class="ml-2 text-sm text-[var(--color-muted)]">
                  {category.subcategories.length} подкатегории
                </span>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h2 class="text-2xl font-semibold">Теги</h2>
        <div class="mt-5 flex flex-wrap gap-2">
          {
            tags.map((tag) => (
              <a
                class="rounded-md border border-[var(--color-border)] px-3 py-2 text-sm"
                href={`/tags/${encodeURIComponent(tag.tag)}`}
              >
                {tag.tag} ({tag.count})
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
