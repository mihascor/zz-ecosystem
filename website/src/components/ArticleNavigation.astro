---
import type { ArticleNavigation as ArticleNavigationData } from '@utils/navigation';

interface Props {
  navigation: ArticleNavigationData;
}

const { navigation } = Astro.props;
---

<nav class="site-border-t mt-12 grid gap-4 pt-8 md:grid-cols-2" aria-label="Навигация по статьям">
  <div>
    {
      navigation.previous ? (
        <a
          class="site-border block rounded-md bg-[var(--color-surface)] p-4"
          href={`/articles/${navigation.previous.data.slug}`}
        >
          <span class="text-sm text-[var(--color-muted)]">Предыдущая статья</span>
          <strong class="mt-1 block">{navigation.previous.data.title}</strong>
        </a>
      ) : (
        <span class="site-border block rounded-md p-4 text-sm text-[var(--color-muted)]">
          Предыдущей статьи нет
        </span>
      )
    }
  </div>
  <div>
    {
      navigation.next ? (
        <a
          class="site-border block rounded-md bg-[var(--color-surface)] p-4 md:text-right"
          href={`/articles/${navigation.next.data.slug}`}
        >
          <span class="text-sm text-[var(--color-muted)]">Следующая статья</span>
          <strong class="mt-1 block">{navigation.next.data.title}</strong>
        </a>
      ) : (
        <span class="site-border block rounded-md p-4 text-sm text-[var(--color-muted)] md:text-right">
          Следующей статьи нет
        </span>
      )
    }
  </div>
</nav>
