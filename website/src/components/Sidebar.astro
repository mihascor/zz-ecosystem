---
import type { CategoryTree as CategoryTreeData } from '@utils/categories';
import CategoryTree from './CategoryTree.astro';
import SidebarToggle from './SidebarToggle.astro';

interface Props {
  categoryTree: CategoryTreeData;
  currentSlug?: string;
}

const { categoryTree, currentSlug } = Astro.props;
---

<div data-sidebar-root data-sidebar-state="visible">
  <button
    class="site-border rounded-md bg-[var(--color-surface)] px-3 py-2 text-sm font-medium"
    type="button"
    data-sidebar-open
  >
    Открыть навигацию
  </button>

  <aside
    class="site-border rounded-md bg-[var(--color-surface)] p-4"
    data-sidebar-panel
  >
    <div class="flex items-center justify-between gap-3">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-[var(--color-muted)]">
        Навигация
      </h2>
      <SidebarToggle />
    </div>
    <div class="mt-4 flex flex-wrap gap-2">
      <button
        class="site-border rounded-md px-2.5 py-1.5 text-sm"
        type="button"
        data-category-expand-all
      >
        Развернуть все
      </button>
      <button
        class="site-border rounded-md px-2.5 py-1.5 text-sm"
        type="button"
        data-category-collapse-all
      >
        Скрыть все
      </button>
    </div>
    <div class="mt-5">
      <CategoryTree categoryTree={categoryTree} currentSlug={currentSlug} />
    </div>
  </aside>
</div>
