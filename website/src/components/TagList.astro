---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

<div class="flex flex-wrap gap-2">
  {
    tags.map((tag) => (
      <a
        class="site-border rounded-md px-3 py-1 text-sm"
        href={`/tags/${encodeURIComponent(tag)}`}
      >
        {tag}
      </a>
    ))
  }
</div>
