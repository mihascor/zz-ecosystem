---
import ThemeToggle from './ThemeToggle.astro';
---

<header class="site-header site-border-b">
  <div class="mx-auto flex max-w-6xl flex-col gap-4 px-6 py-px md:flex-row md:items-center md:justify-between">
    <a class="inline-flex items-center" href="/" aria-label="На главную">
      <img class="h-[70px] w-auto" src="/logo.png" alt="Запретные знания" />
    </a>
    <div class="flex flex-col gap-4 md:flex-row md:items-center">
      <nav class="flex flex-wrap gap-4 text-sm text-[var(--color-muted)]" aria-label="Основная навигация">
        <a href="/articles">Статьи</a>
      </nav>
      <ThemeToggle />
    </div>
  </div>
</header>
