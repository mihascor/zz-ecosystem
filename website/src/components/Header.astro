---
import ThemeToggle from './ThemeToggle.astro';
---

<header class="border-b border-[var(--color-border)] bg-[var(--color-surface)]">
  <div class="mx-auto flex max-w-6xl flex-col gap-4 px-6 py-4 md:flex-row md:items-center md:justify-between">
    <a class="text-lg font-semibold" href="/">Запретные знания</a>
    <div class="flex flex-col gap-4 md:flex-row md:items-center">
      <nav class="flex flex-wrap gap-4 text-sm text-[var(--color-muted)]" aria-label="Основная навигация">
        <a href="/articles">Статьи</a>
      </nav>
      <ThemeToggle />
    </div>
  </div>
</header>
